# === TRACE service configuration (example) ===
# Copy to .env.local for local dev. NEVER commit real secrets.

# App
ENVIRONMENT=development           # development | staging | production
APP_VERSION=0.1.0

# Auth (Clerk) — platform standard, App 3 "TrueVow-Tenants"
AUTH_MODE=local                   # local (dev/test, HS256) | clerk (prod, JWKS RS256)
LOCAL_JWT_SECRET=change-me-in-dev
CLERK_JWKS_URL=
CLERK_ISSUER=
CLERK_AUDIENCE=

# Operational database (Supabase Postgres). Leave unset to use in-memory SQLite.
TRACE_DATABASE_URL=
# Separate PHI store (Supabase Postgres, pgcrypto AES-256)
TRACE_PHI_DATABASE_URL=

# Object storage (Supabase Storage — platform standard)
STORAGE_PROVIDER=supabase
STORAGE_SUPABASE_URL=
STORAGE_SUPABASE_SERVICE_ROLE_KEY=
STORAGE_BUCKET=trace-medical-records
PRESIGNED_URL_EXPIRY_SECONDS=900

# DocuSeal (self-hosted e-signature on Fly.io — AGPL-3.0)
DOCUSEAL_API_URL=https://sign.internal    # Fly.io private network URL
DOCUSEAL_API_TOKEN=
DOCUSEAL_WEBHOOK_SECRET=
DOCUSEAL_SIGNING_LINK_EXPIRY_DAYS=7

# Cloud fax (Documo primary — $25/mo HIPAA every plan, HITRUST CSF, IDP)
FAX_PROVIDER=documo                 # documo | faxplus | srfax
DOCUMO_API_KEY=
FAXPLUS_API_KEY=
SRFAX_ACCESS_ID=
SRFAX_ACCESS_PWD=
FAX_RETURN_NUMBER=

# Billing reconciliation LLM (Azure OpenAI primary — auto BAA under MS DPA)
LLM_SERVICE_PROVIDER=azure_openai   # azure_openai | deepseek_api | anthropic

# Clinical NLP (Phase 1C: provider extraction from intake transcripts)
NLP_PROVIDER_BACKEND=openmed             # openmed | disabled

# Long-context NLP (Phase 1D — evaluate BioClinical ModernBERT)
NLP_LONG_CONTEXT_BACKEND=disabled        # disabled | bioclinical_modernbert

# Billing LLM (Phase 1D — disabled in Phase 1C per ADR-003 §13)
LLM_BACKEND=disabled                     # disabled | azure_openai | deepseek_api | anthropic
LLM_PHI_ALLOWED=false                    # must be true before any PHI-adjacent prompt

# Observability (platform standard: SigNoz via OTEL + Sentry)
OTEL_EXPORTER_OTLP_ENDPOINT=
SENTRY_DSN=
